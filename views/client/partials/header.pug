include ../mixins/sub-menu.pug

header.header
  .container
    .row.align-items-center
      .col-3
        .inner-logo
          a(href="/")
            img(src="/images/file.svg", alt="Logo")

      .col-4
        form(action="/search" method="GET")
          .input-group
            input.form-control(
              type="text"
              placeholder="Nhập từ khóa..."
              name="keyword"
              value=keyword
            )
            button.btn.btn-info(type="submit") Tìm kiếm
            
      .col-5
        .inner-menu
          ul 
            li
              a(
                class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover"
                href="/"
              ) Trang chủ
              

            li(class="sub-menu")
              - const pathProduct = "/products"; 
              a(
                class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover"
                href="/products"
              ) Sản phẩm
              +sub-menu(layoutProductsCategory, pathProduct)
            
            li(class="sub-menu")
              - const pathArticles = "/articles"; 
              a(
                class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover"
                href="/articles"
              ) Bài viết
              +sub-menu(layoutArticlesCategory, pathArticles)