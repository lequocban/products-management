include ../mixins/sub-menu.pug

header.header
  .container
    .row.align-items-center
      .col-2
        .inner-logo
          a(href="/")
            img(src=settingGeneral.WebsiteLogo, alt="Logo" style="max-height: 50px;")

      .col-4
        form(action="/search" method="GET")
          .input-group
            input.form-control(
              type="text"
              placeholder="Nhập từ khóa..."
              name="keyword"
              value=keyword
            )
            button.btn.btn-info(type="submit") Tìm kiếm
            
      .col-6
        .inner-menu
          ul.d-flex.align-items-center.justify-content-end.mb-0.ps-0.gap-3(style="list-style:none;") 
            li
              a(
                class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-dark fw-bold"
                href="/"
              ) Trang chủ
              
            li(class="sub-menu")
              - const pathProduct = "/products"; 
              a(
                class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-dark fw-bold"
                href="/products"
              ) Sản phẩm
              +sub-menu(layoutProductsCategory, pathProduct)
            
            li(class="sub-menu")
              - const pathArticles = "/articles"; 
              a(
                class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-dark fw-bold"
                href="/articles"
              ) Bài viết
              +sub-menu(layoutArticlesCategory, pathArticles)

            //- Nút Giỏ hàng
            li
              a(
                class="position-relative d-inline-block link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-dark mt-1"
                href="/cart"
                title="Giỏ hàng"
              )
                i.fa-solid.fa-cart-shopping.fs-5
                span.position-absolute.top-10.start-100.translate-middle.badge.rounded-pill.bg-danger(
                  style="font-size: 10px; padding: 3px 5px;"
                ) #{miniCart ? miniCart.totalQuantity : "0"}
                
            //- Nút Đơn hàng
            li
              a(
                class="d-inline-block link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-dark mt-1"
                href="/orders"
                title="Đơn hàng của tôi"
              )
                i.fa-solid.fa-clipboard-list.fs-5
             
            if !user
              li.ms-1
                a(
                  href="/user/login" 
                  class="btn btn-outline-primary rounded-pill px-3 py-1 text-nowrap" 
                  style="font-size: 13px; font-weight: 600; border-width: 1.5px;"
                ) Đăng nhập

              li.ms-1
                a(
                  href="/user/register" 
                  class="btn btn-primary rounded-pill px-3 py-1 text-nowrap" 
                  style="font-size: 13px; font-weight: 600;"
                ) Đăng ký
            
            else
              li.dropdown.ms-4
                //- Nút bấm (Icon User)
                a(
                  class="d-inline-block text-dark mt-1"
                  href="#"
                  role="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  title="Tài khoản của tôi"
                )
                  i.fa-regular.fa-circle-user.fs-4

                //- Menu xổ xuống 
                //- (Dùng dropdown-menu-end để menu mở canh lề phải, không bị tràn ra ngoài màn hình)
                ul.dropdown-menu.dropdown-menu-end.shadow.border-0.mt-2
                  //- Thông tin tài khoản
                  li
                    a.dropdown-item.py-2(href="/user/info") 
                      i.fa-regular.fa-id-badge.me-2.text-primary
                      | Thông tin tài khoản
                      
                  //- Đường kẻ ngang phân cách
                  li
                    hr.dropdown-divider.my-1
                    
                  //- Nút Đăng xuất (Đổi màu đỏ cảnh báo)
                  li
                    a.dropdown-item.py-2.text-danger(href="/user/logout") 
                      i.fa-solid.fa-right-from-bracket.me-2
                      | Đăng xuất

  link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css")