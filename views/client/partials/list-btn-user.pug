.row
  .col-12 
    a(
      class="btn btn-primary m-1"
      href="/users/not-friends"
    ) Danh sách người dùng
    a(
      class="btn btn-primary m-1"
      href="/users/friends"
    ) Danh sách bạn bè
    a(
      class="btn btn-primary m-1"
      href="/users/requests"
    ) Lời mời đă gửi
    a(
      class="btn btn-primary m-1"
      href="/users/accept"
    ) 
      | Lời mời kết bạn
      span(
        class="badge badge-light"
        badge-user-accept=user.id
      ) #{user.acceptFriends.length}