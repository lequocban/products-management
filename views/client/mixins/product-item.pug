mixin product-item(item)
  .col-4.mb-4 
    .product-item
      .inner-image
        a(href=`/products/${item.slug}`)
          img(src=item.thumbnail, alt=item.title)
          if(item.featured == "1")
            .inner-featured Nổi bật
      .inner-content
        h3.inner-title 
          a(
            class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-dark"
            href=`/products/${item.slug}`
          ) #{item.title}
        .inner-price-new #{item.newPrice}$
        .inner-price-old #{item.price}$
        .inner-discount -#{item.discountPercentage}%