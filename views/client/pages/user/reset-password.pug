extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-error(5000)
  +alert-success(5000)

  .container.my-5
    .row.justify-content-center
      .col-md-8.col-lg-5
        .card.shadow.border-0.rounded-4
          .card-header.bg-white.text-center.pt-4.pb-2.border-bottom-0
            h2.fw-bold.text-primary 
              i.fa-solid.fa-key.me-2
              | Đặt lại mật khẩu
            p.text-muted.small Vui lòng nhập mật khẩu mới cho tài khoản của bạn.
          
          .card-body.p-4
            form(
              action="/user/password/reset"
              method="POST"
            )
              .mb-3
                label.form-label.fw-bold(for="password") Mật khẩu mới
                .position-relative
                  input#password.form-control.form-control-lg.rounded-3(
                    type="password"
                    name="password"
                    required
                    placeholder="Nhập mật khẩu mới..."
                    style="padding-right: 40px;" 
                  )

                  span.toggle-password.position-absolute.top-50.end-0.translate-middle-y.pe-3(
                    style="cursor: pointer; color: #6c757d;"
                  )
                    i.fa-regular.fa-eye.fs-5

              .mb-4
                label.form-label.fw-bold(for="confirmPassword") Xác nhận mật khẩu mới
                .position-relative
                  input#confirmPassword.form-control.form-control-lg.rounded-3(
                    type="password"
                    name="confirmPassword"
                    required
                    placeholder="Nhập lại mật khẩu mới..."
                    style="padding-right: 40px;" 
                  )
                  span.toggle-password.position-absolute.top-50.end-0.translate-middle-y.pe-3(
                    style="cursor: pointer; color: #6c757d;"
                  )
                    i.fa-regular.fa-eye.fs-5

              .d-grid.mt-4
                button.btn.btn-primary.btn-lg.rounded-pill.fw-bold(type="submit") 
                  i.fa-solid.fa-rotate.me-2
                  | Đổi mật khẩu

          .card-footer.bg-white.text-center.pb-4.border-top-0
            a.text-muted.text-decoration-none(href="/user/login") 
              i.fa-solid.fa-arrow-left.me-1
              span.ms-1 Quay lại trang đăng nhập