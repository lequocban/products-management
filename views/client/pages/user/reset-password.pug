extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-error(5000)
  +alert-success(5000)

  .container.my-5.cyber-wrapper.rounded-5
    .row.justify-content-center
      .col-md-8.col-lg-5
        .glass-card.shadow-lg.rounded-5.overflow-hidden
          .card-header.text-center.pt-4.pb-2.border-bottom-0(style="background: transparent;")
            h2.cyber-text.fw-bold 
              i.fa-solid.fa-key.me-2
              | Đặt lại mật khẩu
            p.text-light.small Vui lòng nhập mật khẩu mới cho tài khoản của bạn.
          
          .card-body.p-4
            form(
              action="/user/password/reset"
              method="POST"
            )
              .form-floating.mb-3.position-relative
                input#password.form-control.cyber-input.rounded-4(
                  type="password"
                  name="password"
                  required
                  placeholder="Nhập mật khẩu mới..."
                  style="padding-right: 50px;" 
                )
                label.fw-bold(for="password") Mật khẩu mới

                span.toggle-password.position-absolute.top-50.end-0.translate-middle-y.pe-3(
                  style="cursor: pointer; color: #adb5bd; z-index: 5;"
                )
                  i.fa-regular.fa-eye.fs-5

              .form-floating.mb-4.position-relative
                input#confirmPassword.form-control.cyber-input.rounded-4(
                  type="password"
                  name="confirmPassword"
                  required
                  placeholder="Nhập lại mật khẩu mới..."
                  style="padding-right: 50px;" 
                )
                label.fw-bold(for="confirmPassword") Xác nhận mật khẩu mới

                span.toggle-password.position-absolute.top-50.end-0.translate-middle-y.pe-3(
                  style="cursor: pointer; color: #adb5bd; z-index: 5;"
                )
                  i.fa-regular.fa-eye.fs-5

              .d-grid.mt-4
                button.btn.btn-cyber.btn-lg.rounded-pill.fw-bold(type="submit") 
                  i.fa-solid.fa-rotate.me-2
                  | Đổi mật khẩu

          .card-footer.text-center.pb-4.border-top-0(style="background: transparent;")
            a.cyber-text.text-decoration-none(href="/user/login") 
              i.fa-solid.fa-arrow-left.me-1
              span.ms-1 Quay lại trang đăng nhập