extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-error(5000)
  +alert-success(5000)

  .container.my-5.cyber-wrapper.rounded-5
    .row.justify-content-center
      //- Giữ nguyên kích thước col-md-8 col-lg-5 để đồng bộ với trang Login
      .col-md-8.col-lg-5
        .glass-card.shadow-lg.rounded-5.overflow-hidden
          .card-header.text-center.pt-4.pb-2.border-bottom-0(style="background: transparent;")
            //- Đổi icon thành hình ổ khóa mở
            h2.cyber-text.fw-bold 
              i.fa-solid.fa-unlock-keyhole.me-2
              | Quên mật khẩu
            p.text-light.small Vui lòng nhập email đã đăng ký để nhận mã xác thực (OTP)
          
          .card-body.p-4
            form(
              action="/user/password/forgot"
              method="POST"
            )
              //- Ô nhập Email
              .form-floating.mb-4
                input#email.form-control.cyber-input.rounded-4(
                  type="email"
                  name="email"
                  required
                  placeholder="Nhập email tài khoản của bạn..."
                )
                label.fw-bold(for="email") Email của bạn

              //- Nút Submit
              .d-grid.mt-4
                button.btn.btn-cyber.btn-lg.rounded-pill.fw-bold(type="submit") 
                  i.fa-solid.fa-paper-plane.me-2
                  | Gửi mã xác nhận

          //- Footer của Card: Nút quay lại trang đăng nhập (trong trường hợp khách nhớ ra pass)
          .card-footer.text-center.pb-4.border-top-0(style="background: transparent;")
            a.cyber-text.text-decoration-none(href="/user/login") 
              i.fa-solid.fa-arrow-left.me-1
              span.ms-1 Quay lại trang đăng nhập