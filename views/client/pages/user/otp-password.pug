extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-error(5000)
  +alert-success(5000)

  .container.my-5.cyber-wrapper.rounded-5
    .row.justify-content-center
      .col-md-8.col-lg-5
        .glass-card.shadow-lg.rounded-5.overflow-hidden
          .card-header.text-center.pt-4.pb-2.border-bottom-0(style="background: transparent;")
            h2.cyber-text.fw-bold 
              i.fa-solid.fa-shield-halved.me-2
              | Xác thực OTP
            p.text-light.small Mã xác thực gồm 6 chữ số đã được gửi đến email của bạn.
            
            //- (Tùy chọn) Hiển thị email để khách an tâm
            if email
              p.fw-bold.text-white.mb-0 #{email}
          
          .card-body.p-4
            form(
              action="/user/password/otp"
              method="POST"
            )
              //- Thẻ ẩn lưu email để gửi lên kèm theo mã OTP (giúp Backend biết đang check OTP của ai)
              input(type="hidden" name="email" value=email)

              //- Khối 6 ô nhập OTP
              .d-flex.justify-content-center.gap-2.mb-4
                - for (var i = 0; i < 6; i++)
                  input.form-control.cyber-input.text-center.otp-input.rounded-3(
                    type="text"
                    name="otp" 
                    maxlength="1"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                    style="width: 45px; height: 55px; font-size: 20px; font-weight: bold;"
                  )

              //- Nút Submit
              .d-grid.mt-2
                button.btn.btn-cyber.btn-lg.rounded-pill.fw-bold(type="submit") 
                  i.fa-solid.fa-circle-check.me-2
                  | Xác nhận


  script(src="/js/otp.js") 