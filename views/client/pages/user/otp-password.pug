extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-error(5000)
  +alert-success(5000)

  .container.my-5
    .row.justify-content-center
      .col-md-8.col-lg-5
        .card.shadow.border-0.rounded-4
          .card-header.bg-white.text-center.pt-4.pb-2.border-bottom-0
            h2.fw-bold.text-primary 
              i.fa-solid.fa-shield-halved.me-2
              | Xác thực OTP
            p.text-muted.small Mã xác thực gồm 6 chữ số đã được gửi đến email của bạn.
            
            //- (Tùy chọn) Hiển thị email để khách an tâm
            if email
              p.fw-bold.text-dark.mb-0 #{email}
          
          .card-body.p-4
            form(
              action="/user/password/otp"
              method="POST"
            )
              //- Thẻ ẩn lưu email để gửi lên kèm theo mã OTP (giúp Backend biết đang check OTP của ai)
              input(type="hidden" name="email" value=email)

              //- Khối 6 ô nhập OTP
              .d-flex.justify-content-center.gap-2.mb-4
                - for (var i = 0; i < 6; i++)
                  input.form-control.form-control-lg.text-center.otp-input.rounded-3(
                    type="text"
                    name="otp" 
                    maxlength="1"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                    style="width: 45px; height: 55px; font-size: 20px; font-weight: bold;"
                  )

              //- Nút Submit
              .d-grid.mt-2
                button.btn.btn-primary.btn-lg.rounded-pill.fw-bold(type="submit") 
                  i.fa-solid.fa-circle-check.me-2
                  | Xác nhận

          //- Footer: Nút gửi lại mã (Có thể làm thêm bộ đếm ngược thời gian ở đây sau)
          .card-footer.bg-white.text-center.pb-4.border-top-0
            span.text-muted Chưa nhận được mã? 
            a.text-primary.fw-bold.text-decoration-none.ms-1(href="javascript:void(0)") Gửi lại

  script(src="/js/otp.js") 