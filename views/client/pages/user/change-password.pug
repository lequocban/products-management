extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main 
  +alert-error(5000)

  .container.my-5
    .row.justify-content-center
      .col-md-8.col-lg-5
        .glass-card.shadow-lg.rounded-5.overflow-hidden
          .card-header.text-center.pt-4.pb-2.border-bottom-0(style="background: transparent;")
            h3.cyber-text.fw-bold 
              i.fa-solid.fa-shield-halved.me-2
              | Đổi mật khẩu
            p.text-light.small Vui lòng xác nhận mật khẩu hiện tại để tiếp tục.

          .card-body.p-4
            form(action="/user/password/change" method="POST")
              
              //- Nhập mật khẩu cũ
              .form-floating.mb-4.position-relative
                input#oldPassword.form-control.cyber-input.rounded-4(
                  type="password"
                  name="oldPassword"
                  required
                  placeholder="Nhập mật khẩu đang sử dụng..."
                )
                label.fw-bold(for="oldPassword") Mật khẩu hiện tại
                span.toggle-password.position-absolute.top-50.end-0.translate-middle-y.pe-3(
                  style="cursor: pointer; color: #adb5bd; z-index: 5;"
                )
                  i.fa-regular.fa-eye.fs-5
              
              //- Nút Tiếp tục
              .d-grid.mt-2
                button.btn.btn-cyber.btn-lg.rounded-pill.fw-bold.text-white(type="submit") 
                  | Tiếp tục xác thực OTP
                  i.fa-solid.fa-arrow-right.ms-2

          .card-footer.text-center.pb-4.border-top-0(style="background: transparent;")
            a.btn.btn-outline-light.rounded-pill.px-4(href="/user/info") 
              i.fa-solid.fa-arrow-left.me-2
              | Quay lại