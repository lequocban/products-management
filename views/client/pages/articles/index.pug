extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/article-layout.pug

block main
  .container.my-4
    .row
      //- =========================================
      //- CỘT TRÁI (Nội dung chính - Chiếm 8/12 cột)
      //- =========================================
      .col-lg-9.pe-lg-4
        
        //- Khối 1: Bài viết nổi bật (Nằm trên cùng của cột trái)
        if articlesFeatured && articlesFeatured.length > 0
          .section-featured.mb-5.pb-4.border-bottom
            +box-head("Bài viết nổi bật")
            
            //- Trong không gian col-lg-8, mixin col-md-4 sẽ hiển thị 3 bài/dòng rất vừa vặn
            +article-grid(articlesFeatured)

        //- Khối 2: Toàn bộ bài viết (Nằm dưới khối nổi bật)
        .section-all-articles.mb-5#danh-sach-bai-viet
          +box-head(pageTitle)
          
          if articles && articles.length > 0
            +article-grid(articles)
          else 
            p.text-muted.fst-italic Đang cập nhật bài viết...

      //- =========================================
      //- CỘT PHẢI (Sidebar - Chiếm 4/12 cột)
      //- =========================================
      .col-lg-3
        .sidebar-new-articles.ms-auto(style="position: sticky; top: 100px; z-index: 10;")
          .card.border-0.shadow-sm
            .card-header.bg-primary.text-white.py-3
              h5.mb-0.fw-bold 
                i.fa-regular.fa-newspaper.me-2
                | Tin tức mới nhất
            
            .card-body.p-0
              if articlesNew && articlesNew.length > 0
                .list-group.list-group-flush
                  //- Hiển thị danh sách tin dạng thu gọn (Ảnh nhỏ bên trái, chữ bên phải)
                  each item in articlesNew
                    a.list-group-item.list-group-item-action.d-flex.align-items-center.p-3(href=`/articles/detail/${item.slug}`)
                      
                      //- Ảnh thumbnail thu nhỏ
                      img.rounded.me-3(
                        src=(item.thumbnail || "/images/no-image.png")
                        alt=item.title
                        style="width: 80px; height: 60px; object-fit: cover; flex-shrink: 0;"
                      )
                      
                      //- Tiêu đề & Ngày đăng
                      div
                        h6.mb-1.text-dark.fw-bold(
                          style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: 14px;"
                        ) #{item.title}
                        
                        if item.createdBy && item.createdBy.createdAt
                          small.text-muted(style="font-size: 12px;") 
                            | #{new Date(item.createdBy.createdAt).toLocaleDateString("vi-VN")}
              else
                p.p-3.text-muted.mb-0 Không có tin mới.