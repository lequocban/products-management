extends ../../layouts/default.pug

block main 
  .container.my-5.py-5.cyber-wrapper.rounded-5
    .row.justify-content-center.align-items-center
      .col-md-8.text-center.glass-card.p-5.rounded-5.shadow-lg
        //- Khối số 404 khổng lồ
        h1.fw-bold.cyber-text(style="font-size: 120px; text-shadow: 2px 2px 10px rgba(0,240,255,0.5); line-height: 1;") 404
        
        //- Icon cảnh báo thân thiện
        .mb-4.mt-3
          i.fa-solid.fa-face-frown-open.text-warning(style="font-size: 60px;")
        
        //- Tiêu đề lỗi
        h2.fw-bold.mb-3.text-white Ôi không! Không tìm thấy trang.
        
        //- Lời giải thích
        p.text-muted.fs-5.mb-5
          | Rất tiếc, trang bạn đang tìm kiếm không tồn tại, đã bị đổi tên hoặc tạm thời không thể truy cập.
          br
          | Vui lòng kiểm tra lại đường dẫn hoặc quay về trang chủ nhé!

        //- Khối nút điều hướng
        .d-flex.justify-content-center.gap-3
          //- Nút Lùi lại trang trước
          a.btn.btn-outline-light.btn-lg.rounded-pill.px-4(href="javascript:history.back()") 
            i.fa-solid.fa-arrow-left.me-2
            | Quay lại
            
          //- Nút Về thẳng trang chủ
          a.btn.btn-cyber.btn-lg.rounded-pill.px-4(href="/") 
            i.fa-solid.fa-house.me-2
            | Về Trang chủ