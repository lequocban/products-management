extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-success(5000)
  +alert-error(5000)

  .container.mt-4.mb-5.cyber-wrapper.rounded-5
    
    //- Nút quay lại (UX tốt cho trang chi tiết)
    .row.mb-3
      .col-12
        a.btn.btn-sm.btn-outline-light.rounded-pill(href="javascript:history.back()") 
          i.fa-solid.fa-arrow-left.me-2
          | Quay lại

    .row
      //- ===== 1. Cột Ảnh Sản Phẩm =====
      .col-md-5.mb-4
        .product-image-box.position-relative.glass-card.p-3.rounded-5.text-center
          img.main-image.img-fluid.rounded-4.border-0.shadow-lg(
            src=product.thumbnail || "/images/no-image.png"
            alt=product.title
            style="width: 100%; aspect-ratio: 1/1; object-fit: cover;"
          )
          
          //- Huy hiệu Nổi bật đè lên ảnh
          if product.featured == "1"
            span.badge.bg-info.position-absolute.shadow(style="top: 20px; right: 20px; font-size: 14px;") Nổi bật

      //- ===== 2. Cột Thông Tin Sản Phẩm =====
      .col-md-7.glass-card.p-4.rounded-5.border-0.shadow-lg
        h1.cyber-text.product-title.fw-bold.mb-3 #{product.title}

        //- Danh mục (Cần populate "product_category_id" ở Controller)
        if product.product_category_id && product.product_category_id.title
          .mb-2
            span.text-muted Danh mục: 
            a(href=`/products/${product.product_category_id.slug}` class="text-decoration-none fw-bold") #{product.product_category_id.title}

        //- Trạng thái
        .mb-3
          span.text-muted Trạng thái: 
          if product.status == "active"
            span.badge.bg-success Còn hàng
          else
            span.badge.bg-danger Hết hàng

        //- Khối hiển thị Giá nổi bật
        .price-box.p-3.rounded-4.mb-4(style="background: rgba(255,255,255,0.05); border: 1px solid var(--cyber-blue);")
          if product.discountPercentage > 0
            .old-price.text-danger.text-decoration-line-through.mb-1
              | Giá gốc: #{product.price}$
            .new-price.text-success.fw-bold.fs-2
              //- product.newPrice được tính từ Helper bên Controller
              | #{product.newPrice}$ 
              span.badge.bg-danger.ms-2.fs-6.align-middle -#{product.discountPercentage}%
          else
            .new-price.text-success.fw-bold.fs-2
              | #{product.price}$

        //- ===== Khu vực Mua Hàng (Chỉ hiện khi còn hàng) =====
        if product.status == "active" && product.stock > 0
          .mb-3
            span.text-muted Tồn kho: 
            strong #{product.stock} 
            span.text-muted sản phẩm

          //- Form gửi dữ liệu thêm vào giỏ hàng
          form(
            action=`/cart/add/${product.id}`
            method="POST"
          )
            .d-flex.align-items-center.mb-4
              label.me-3.text-light.fw-bold(for="quantity") Số lượng:
              input.form-control.cyber-input.quantity-input.rounded-pill.text-center(
                type="number"
                name="quantity"
                id="quantity"
                min="1"
                max=product.stock
                value="1"
                style="width: 100px;"
              )
            
            button.btn.btn-cyber.btn-lg.me-2.rounded-pill(type="submit") 
              i.fa-solid.fa-cart-plus.me-2
              | Thêm vào giỏ hàng
            button.btn.btn-outline-light.btn-lg.rounded-pill(type="button") 
              i.fa-solid.fa-money-bill-wave.me-2
              | Mua ngay
              
        else 
          .alert.alert-warning.mt-3 Sản phẩm hiện đang tạm hết hàng. Vui lòng quay lại sau!

    //- ===== 3. Cột Mô Tả Chi Tiết =====
    .row.mt-5
      .col-12
        //- Đã giảm bo góc xuống rounded-4 và có thể bỏ overflow-hidden nếu không cần thiết
        .glass-card.border-0.shadow-lg.rounded-4
          .card-header.border-bottom-0.pt-4.pb-0.px-4(style="background: transparent;")
            h4.cyber-text.mb-0 Mô tả chi tiết
            
          //- Thêm class p-4 (padding) để đẩy chữ lùi vào trong, không bị lẹm vào góc
          .card-body.text-light.p-4

            if product.description
              //- Sử dụng !{} để render các thẻ HTML từ trình soạn thảo (như TinyMCE)
              .content-rendered.border-top.pt-3
                | !{product.description}
            else
              p.text-muted.border-top.pt-3 Đang cập nhật mô tả...