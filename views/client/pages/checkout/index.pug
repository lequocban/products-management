extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main 
  +alert-success(5000)  
  +alert-error(5000)

  .container.my-3 
    .row.mb-3.mt-3
      .col-12
        a.btn.btn-sm.btn-outline-secondary(href="javascript:history.back()") 
          | ← Quay lại
    .row 
      .col-12
        +box-head("Đặt hàng")

    .row 
      .col-12 
        table.table.table-bordered
          thead
            tr
              th STT
              th Ảnh
              th Tên sản phẩm
              th Giá
              th Số lượng
              th Thành tiền

          tbody
            if cartDetail.products.length > 0
              each item, index in cartDetail.products
                tr 
                  td #{index + 1}
                  td 
                    img(
                      src=item.product_id.thumbnail, 
                      alt=item.product_id.title, 
                      style="width: 80px; height: 80px; object-fit: cover; border-radius: 5px;"   
                    )
                  td  #{item.product_id.title}
                  td #{item.product_id.newPrice} $
                  td #{item.quantity}
                  td #{item.totalPrice} $

            else
              tr
                td(colspan="8").text-center.py-5
                  h3 Đơn hàng của bạn đang trống.

        if cartDetail.products.length > 0
          h3(class="text-end") Tổng cộng: #{cartDetail.totalPrice} $
      
    if cartDetail.products.length > 0
      .row
        .col-12
          .card.p-4.my-4 
            form(
              action="checkout/order",
              method="POST"
            ) 
              div(class="form-group mb-3") 
                label(for="fullName") Họ và tên
                input.form-control(
                  type="text"
                  name="fullName" 
                  id="fullName"
                  required
                )
              div(class="form-group mb-3") 
                label(for="phone") Số điện thoại
                input.form-control(
                  type="text"
                  name="phone" 
                  id="phone"
                  required
                )
              div(class="form-group mb-3") 
                label(for="address") Địa chỉ
                input.form-control(
                  type="text"
                  name="address" 
                  id="address"
                  required
                )
              div(class="form-group")
                button.btn.btn-success(type="submit") Đặt hàng  