extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
  .container.mb-5.cyber-wrapper.rounded-5
    .row.mt-4.mb-3
      .col-12
        +box-head("Đơn hàng của tôi")

    .row 
      .col-12 
        if orders && orders.length > 0
          .glass-card.shadow-lg.rounded-5.overflow-hidden
            .card-body.p-0
              .table-responsive
                table.table.text-white.mb-0(style="background: transparent;")
                  thead(style="border-bottom: 2px solid var(--cyber-blue);")
                    tr
                      th.text-center STT
                      th Mã đơn hàng
                      th Ngày đặt
                      th Trạng thái
                      th Tổng tiền
                      th.text-center Hành động
                  
                  tbody
                    each order, index in orders
                      tr.align-middle(style="border-bottom: 1px solid rgba(255,255,255,0.1);")
                        td.text-center #{index + 1}
                        td
                          span.cyber-text.fw-bold #{order._id}
                        td 
                          //- Hiển thị ngày tháng theo chuẩn Việt Nam
                          - var date = new Date(order.createdAt).toLocaleString("vi-VN")
                          | #{date}
                        td
                          if order.status == "pending"
                            span.badge.bg-warning.text-dark Chờ xử lý
                          else if order.status == "processing"
                            span.badge.bg-info.text-dark Đang xử lý/Đóng gói
                          else if order.status == "shipped"
                            span.badge.bg-primary Đã giao vận chuyển
                          else if order.status == "delivered"
                            span.badge.bg-success Đã giao hàng
                          else if order.status == "cancelled"
                            span.badge.bg-danger Đã hủy
                          else if order.status == "returned"
                            span.badge.bg-dark Đã trả hàng
                          else 
                            span.badge.bg-secondary #{order.status}
                        td.fw-bold.text-danger #{order.totalPrice} $
                        td.text-center
                          a.btn.btn-sm.btn-outline-info(href=`/orders/detail/${order._id}`) 
                            i.fa-solid.fa-eye.me-1
                            | Xem chi tiết
        else
          .text-center.py-5
            img(src="/images/empty-order.png" alt="Không có đơn hàng" style="width: 150px; opacity: 0.5; margin-bottom: 20px;")
            h4.text-muted Bạn chưa có đơn hàng nào.
            a.btn.btn-primary.mt-3(href="/products") Bắt đầu mua sắm ngay