extend ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/form-search.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort-category.pug
include ../../mixins/table-tree.pug

block main 
  if(role.permissions.includes("articles-category_view"))
    +alert-success(5000)
    +alert-error(5000)

        
    h1 Danh mục bài viết 


    .card.mb-3
      .card-header Sắp xếp
        .card-body
          .row 
            .col-4
              +sort-category()

    .card.mb-3
      .card-header Danh sách
        .card-body
          .row 
            .col-8
              +form-change-multi(`${prefixAdmin}/articles-category/change-multi?_method=PATCH`)
            .col-4.text-end
              if(role.permissions.includes("articles-category_create"))
                a(
                  href=`${prefixAdmin}/articles-category/create`
                  class="btn btn-outline-success"
                ) + Thêm mới

      table(
            class="table table-hover table-sm"
            checkbox-multi
          )
            thead
              tr
                th 
                  input(type="checkbox" name="checkall")
                th STT 
                th Hình ảnh 
                th Tiêu đề
                th Vị trí
                if(role.permissions.includes("articles-category_edit"))
                  th Trạng thái
                th Người tạo
                th Cập nhật
                th Hành động

            tbody 
              +table-tree-article(records)

    if(role.permissions.includes("articles-category_edit"))
      form(
        action=""
        method="POST"
        id="form-change-status"
        data-path=`${prefixAdmin}/articles-category/change-status`
      ) 

    if(role.permissions.includes("articles-category_delete"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`${prefixAdmin}/articles-category/delete`
      ) 

    script(src="/admin/js/article-category.js") 
  else 
    h1 Bạn không có quyền truy cập
