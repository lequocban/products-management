extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-error(5000)
  +alert-success(5000)

  h1(class="mb-4") Cài đặt chung

  form(
    action=`${prefixAdmin}/settings/general?_method=PATCH`
    method="POST"
    enctype="multipart/form-data"
  )
    div(class="form-group mb-3")
      label(for="WebsiteName") Tên Website
      input(
        type="text"
        class="form-control"
        id="WebsiteName"
        name="WebsiteName"
        value=(setting ? setting.WebsiteName : "")
      )

    div(
      class="form-group mb-3"
      upload-image
    )
      label(for="WebsiteLogo") Logo Website
      br
      input(
        type="file"
        class="form-control-file"
        id="WebsiteLogo"
        name="WebsiteLogo"
        accept="image/*"
        upload-image-input
      )
      br
      .image-preview-wrapper
        img(
          src=(setting ? setting.WebsiteLogo : "")
          class="image-preview"
          upload-image-preview
        ) 
        span(
          remove-image-preview  
          class="remove-image"
        ) x

    div(class="form-group mb-3")
      label(for="phone") Số điện thoại
      input(
        type="text"
        class="form-control"
        id="phone"
        name="phone"
        value=(setting ? setting.phone : "")
      )

    div(class="form-group mb-3")
      label(for="email") Email
      input(
        type="email"
        class="form-control"
        id="email"
        name="email"
        value=(setting ? setting.email : "")
      )

    div(class="form-group mb-3")
      label(for="address") Địa chỉ
      input(
        type="text"
        class="form-control"
        id="address"
        name="address"
        value=(setting ? setting.address : "")
      )

    div(class="form-group mb-3")
      label(for="copyright") Copyright
      input(
        type="text"
        class="form-control"
        id="copyright"
        name="copyright"
        value=(setting ? setting.copyright : "")
      )

    div(class="form-group mb-3")
      button(
        type="submit"
        class="btn btn-primary"
      ) Cập nhật 