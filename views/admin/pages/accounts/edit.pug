extend ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/render-tree.pug

block main
  +alert-error(5000)
  +alert-success(5000)

  h1(class="mb-4") Chỉnh sửa tài khoản

  div(class="mb-3")
    a(
      href=`${prefixAdmin}/accounts`
      class="btn btn-secondary"
    ) Quay lại

  if(roles)
    form(
      action=`${prefixAdmin}/accounts/edit/${account._id}?_method=PATCH`
      id="form-create-account"
      method="POST"
      enctype="multipart/form-data"
    )
      div(class="form-group mb-3")
        label(for="fullName") Họ và tên *
        input(
          type="text"
          class="form-control"
          id="fullName"
          name="fullName"
          required
          value=account.fullName
        )

      div(class="form-group mb-3")
        label(for="email") Email *
        input(
          type="email"
          class="form-control"
          id="email"
          name="email"
          required
          value=account.email
        )

      div(class="form-group mb-3")
        label(for="password") Mật khẩu *
        input(
          type="password"
          class="form-control"
          id="password"
          name="password"
          placeholder="*Để trống nếu không đổi mật khẩu"
        )
      
      div(class="form-group mb-3")
        label(for="phone") Số điện thoại *
        input(
          type="text"
          class="form-control"
          id="phone"
          name="phone"
          value=account.phone
        )
      
      div(
        class="form-group mb-3"
        upload-image
      )
        label(for="avatar") Ảnh
        input(
          type="file"
          class="form-control-file"
          id="avatar"
          name="avatar"
          accept="image/*"
          upload-image-input
        )
        br
        .image-preview-wrapper
          img(
            src=account.avatar || ""
            class="image-preview"
            upload-image-preview
          ) 
          span(
            remove-image-preview  
            class="remove-image"
          ) x

      div(class="form-group")
        label(for="role_id") Phân quyền
        select(name="role_id" id="role_id" class="form-control") 
          option(disabled) --Chọn--
          each role in roles
            option(
              value=role.id
              selected=(role.id == account.role_id ? true : false)
            ) #{role.title}         

      label Trạng thái
      br
      div(class="form-group form-check form-check-inline mb-3")
        input(
          type="radio"
          class="form-check-input"
          id="statusActive"
          name="status"
          value="active"
          checked=(account.status == "active" ? true : false)
        )
        label(for="statusActive" class="form-check-label") Hoạt động
      div(class="form-group form-check form-check-inline mb-3")
        input(
          type="radio"
          class="form-check-input"
          id="statusInActive"
          name="status"
          value="inactive"
          checked=(account.status == "inactive" ? true : false)
        )
        label(for="statusInActive" class="form-check-label") Dừng hoạt động
      div(class="form-group mb-3")
        button(
          type="submit"
          class="btn btn-primary"
        ) Cập nhật 
  else 
    p Vui lòng tạo nhóm quyền trước khi cập nhật tài khoản
    p 
      a(
      href=`${prefixAdmin}/roles/create`
      class="btn btn-secondary"
      ) Tạo nhóm quyền


  script(src="/admin/js/account.js") 

