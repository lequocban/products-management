extend ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-success(5000)
  +alert-error(5000)
  
  if(role.permissions.includes("accounts_view"))
    h1.mb-4 Chi tiết tài khoản

    .card.product-detail
      .card-body
        .row
          
          //- Cột ảnh đại diện
          .col-md-4
            .image-box
              img.product-image(
                src=record.avatar || "/images/avatar-default.png"
                alt=record.fullName
                style="width: 100%; border-radius: 8px;"
              )

          //- Cột thông tin chi tiết
          .col-md-8
            h3.product-title #{record.fullName}

            hr

            .row.mb-2
              .col-6
                strong Email:
              .col-6
                span #{record.email}

            .row.mb-2
              .col-6
                strong Số điện thoại:
              .col-6
                span #{record.phone}

            .row.mb-2
              .col-6
                strong Nhóm quyền:
              .col-6
                if record.role_id && record.role_id.title
                  span.badge.bg-info.text-dark #{record.role_id.title}
                else 
                  span.text-muted Không xác định
            if(role.permissions.includes("accounts_edit"))
              .row.mb-3
                .col-6
                  strong Trạng thái:
                .col-6
                  if record.status == "active"
                    a(
                      href="javascript:;"
                      data-status="active"
                      data-id=record._id
                      button-change-status
                      class="badge bg-success text-decoration-none"
                    ) Hoạt động
                  else
                    a(
                      href="javascript:;"
                      data-status="inactive"
                      data-id=record._id
                      button-change-status
                      class="badge bg-danger text-decoration-none"
                    ) Dừng hoạt động

            .row.mb-2
              .col-6
                strong Người tạo:
              .col-6
                if record.createdBy && record.createdBy.account_id
                  span.text-primary #{record.createdBy.account_id.fullName} 
                  br
                  small.text-muted (#{new Date(record.createdBy.createdAt).toLocaleString("vi-VN")})
                else 
                  span.text-muted Không xác định

            .row.mb-3
              .col-6
                strong Lịch sử cập nhật:
              .col-6
                if record.updatedBy && record.updatedBy.length > 0
                  //- Đảo ngược mảng để mới nhất lên đầu
                  - const history = [...record.updatedBy].reverse()
                  
                  table.table.table-sm.table-bordered.mt-2
                    thead.table-light
                      tr
                        th Thời gian
                        th Người cập nhật
                        th Id
                    tbody
                      each item in history
                        tr
                          td #{new Date(item.updatedAt).toLocaleString("vi-VN")}
                          td 
                            if item.account_id && item.account_id.fullName
                              | #{item.account_id.fullName}
                          td 
                            if item.account_id && item.account_id.fullName
                              | #{item.account_id.id}
                            else 
                              span.text-muted Không xác định
                else
                  p.text-muted.mt-2.fst-italic Chưa có lịch sử cập nhật.

            hr
            if(role.permissions.includes("accounts_edit"))
              a(
                href=`${prefixAdmin}/accounts/edit/${record._id}`
                class="btn btn-warning"
              ) Sửa

            a(
              href=`${prefixAdmin}/accounts`
              class="btn btn-secondary ms-2"
            ) Quay lại
    if(role.permissions.includes("accounts_edit"))
      form(
        action=""
        method="POST"
        id="form-change-status"
        data-path=`${prefixAdmin}/accounts/change-status`
      )

    script(src="/admin/js/account.js")
  else 
    h1 Bạn không có quyền truy cập