extend ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/render-tree.pug

block main
  +alert-error(5000)

  if(role.permissions.includes("accounts_create"))
    h1(class="mb-4") Thêm mới tài khoản

    div(class="mb-3")
      a(
        href=`${prefixAdmin}/accounts`
        class="btn btn-secondary"
      ) Quay lại
    if(roles)
      form(
        action=`${prefixAdmin}/accounts/create`
        id="form-create-account"
        method="POST"
        enctype="multipart/form-data"
      )
        div(class="form-group mb-3")
          label(for="fullName") Họ và tên *
          input(
            type="text"
            class="form-control"
            id="fullName"
            name="fullName"
            required
          )

        div(class="form-group mb-3")
          label(for="email") Email *
          input(
            type="email"
            class="form-control"
            id="email"
            name="email"
            required
          )

        div(class="form-group mb-3")
          label(for="password") Mật khẩu *
          input(
            type="password"
            class="form-control"
            id="password"
            name="password"
            required
          )
        
        div(class="form-group mb-3")
          label(for="phone") Số điện thoại *
          input(
            type="text"
            class="form-control"
            id="phone"
            name="phone"
          )
        
        div(
          class="form-group mb-3"
          upload-image
        )
          label(for="avatar") Ảnh
          input(
            type="file"
            class="form-control-file"
            id="avatar"
            name="avatar"
            accept="image/*"
            upload-image-input
          )
          br
          .image-preview-wrapper
            img(
              src=""
              class="image-preview"
              upload-image-preview
            ) 
            span(
              remove-image-preview  
              class="remove-image"
            ) x

        div(class="form-group")
          label(for="role_id") Phân quyền
          select(name="role_id" id="role_id" class="form-control") 
            option(disabled) --Chọn--
            each role in roles
              option(value=role.id) #{role.title}         

        label Trạng thái
        br
        div(class="form-group form-check form-check-inline mb-3")
          input(
            type="radio"
            class="form-check-input"
            id="statusActive"
            name="status"
            value="active"
            checked
          )
          label(for="statusActive" class="form-check-label") Hoạt động
        div(class="form-group form-check form-check-inline mb-3")
          input(
            type="radio"
            class="form-check-input"
            id="statusInActive"
            name="status"
            value="inactive"
          )
          label(for="statusInActive" class="form-check-label") Dừng hoạt động
        div(class="form-group mb-3")
          button(
            type="submit"
            class="btn btn-primary"
          ) Tạo mới   
    else 
      p Vui lòng tạo nhóm quyền trước khi tạo tài khoản
      p 
        a(
        href=`${prefixAdmin}/roles/create`
        class="btn btn-secondary"
        ) Tạo nhóm quyền


    script(src="/admin/js/account.js") 

  else 
    h1 Bạn không có quyền truy cập