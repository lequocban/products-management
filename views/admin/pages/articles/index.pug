extend ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/form-search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort.pug
include ../../mixins/moment.pug

block main 

  +alert-success(5000)
  +alert-error(5000)

  if(role.permissions.includes("articles_view"))    
    h1 Danh sách bài viết 

    .card.mb-3
      .card-header Bộ lọc và tìm kiếm
      .card-body
        .row 
          .col-6
            +filter-status(filterStatus)
          .col-6 
            +form-search(keyword)
              
    .card.mb-3
      .card-header Sắp xếp
        .card-body
          .row 
            .col-4
              +sort-category()

    .card.mb-3
      .card-header Danh sách bài viết
        .card-body
          .row 
            .col-8
              if(role.permissions.includes("articles_edit"))
                +form-change-multi(`${prefixAdmin}/articles/change-multi?_method=PATCH`)
            .col-4.text-end
              if(role.permissions.includes("articles_create"))
                a(
                  href=`${prefixAdmin}/articles/create`
                  class="btn btn-outline-success"
                ) + Thêm mới


          table(
            class="table table-hover table-sm"
            checkbox-multi
          )
            thead
              tr
                th 
                  input(type="checkbox" name="checkall")
                th STT 
                th Hình ảnh 
                th Tiêu đề
                if(role.permissions.includes("articles_edit"))
                  th Vị trí
                  th Trạng thái
                th Người tạo
                th Cập nhật
                th Hành động

            tbody 
              each item, index in records
                tr
                  td
                    input(
                      type="checkbox" 
                      name="id"
                      value=item.id
                      ) 
                  td #{pagination.limitItems * (pagination.currentPage - 1) + (index+ 1)}
                  td 
                    img(
                      src=item.thumbnail
                      alt=item.title
                      width="100px"
                      height="auto"
                    ) 
                  td #{item.title}
                  if(role.permissions.includes("articles_edit"))
                    td 
                      input(
                        type="number"
                        value=item.position
                        style='width: 60px'
                        min='1'
                        name="position"
                      )
                  if(role.permissions.includes("articles_edit"))
                    td
                      if (item.status == "active")
                        a(
                          href="javascript:;" 
                          data-status=item.status
                          data-id=item.id
                          button-change-status
                          class="badge bg-success text-decoration-none"
                        ) Hoạt động
                      else 
                        a(
                          href="javascript:;" 
                          data-status=item.status
                          data-id=item.id
                          button-change-status 
                          class="badge bg-danger text-decoration-none"
                        ) Dừng hoạt động
                  td 
                    if item.createdBy && item.createdBy.account_id
                      p #{item.createdBy.account_id.fullName}
                      p 
                        +formatDate(item.createdBy.createdAt)
                  td 
                    -const updatedHistory = item.updatedBy.slice(-1)[0]
                    if updatedHistory && updatedHistory.account_id
                      p #{updatedHistory.account_id.fullName}
                      p 
                        +formatDateTime(updatedHistory.updatedAt)
                  td 
                    a(
                      href=`${prefixAdmin}/articles/detail/${item.id}`
                      class="btn btn-secondary btn-sm ms-1"
                    ) Chi tiết
                    if(role.permissions.includes("articles_edit"))
                      a(
                        href=`${prefixAdmin}/articles/edit/${item.id}`
                        class="btn btn-warning btn-sm ms-1"
                      ) Sửa
                    if(role.permissions.includes("articles_delete"))
                      button(
                        class="btn btn-danger btn-sm ms-1"
                        data-id=item.id
                        button-delete
                      ) Xóa

    +pagination(pagination)
    if(role.permissions.includes("articles_edit"))
      form(
        action=""
        method="POST"
        id="form-change-status"
        data-path=`${prefixAdmin}/articles/change-status`
      ) 
      
    if(role.permissions.includes("articles_delete"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`${prefixAdmin}/articles/delete`
      ) 

    script(src="/admin/js/article.js") 
  else 
    h1 Bạn không có quyền truy cập