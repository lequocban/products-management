extend ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/render-tree.pug

block main
  +alert-error(5000)

  h1(class="mb-4") Thêm mới danh mục sản phẩm

  form(
    action=`${prefixAdmin}/products-category/create`
    method="POST"
    enctype="multipart/form-data"
  )
    div(class="form-group mb-3")
      label(for="title") Tiêu đề
      input(
        type="text"
        class="form-control"
        id="title"
        name="title"
        required
      )
    div(class="form-group mb-3")
      label(for="parent_id") Danh mục cha
      input(type="hidden" name="parent_id" id="parent_id_input" value="")
      .tree-container
        .tree-item.root-item.selected(data-id="")
          .item-content
            span.toggle.empty
            span.title -- Danh mục gốc --
        if(records)
          +render-tree-list(records)

    //- div(class="category-tree-wrapper")
    //-   h5 Danh mục sản phẩm
    //-   if(records)
    //-     +render-tree-list(records)

    div(class="form-group mb-3")
      label(for="desc") Mô tả
      textarea(
        class="form-control textarea-mce"
        id="desc"
        name="description"
        rows="5"
        
      ) 
    div(
      class="form-group mb-3"
      upload-image
    )
      label(for="thumbnail") Ảnh
      input(
        type="file"
        class="form-control-file"
        id="thumbnail"
        name="thumbnail"
        accept="image/*"
        upload-image-input
      )
      br
      .image-preview-wrapper
        img(
          src=""
          class="image-preview"
          upload-image-preview
        ) 
        span(
          remove-image-preview  
          class="remove-image"
        ) x
    
    div(class="form-group mb-3")
      label(for="position") Vị trí
      input(
        type="number"
        class="form-control"
        id="position"
        name="position"
        placeholder="Tự động tăng"
        min="1"
      )

    
    label Trạng thái
    br
    div(class="form-group form-check form-check-inline mb-3")
      input(
        type="radio"
        class="form-check-input"
        id="statusActive"
        name="status"
        value="active"
        checked
      )
      label(for="statusActive" class="form-check-label") Hoạt động
    div(class="form-group form-check form-check-inline mb-3")
      input(
        type="radio"
        class="form-check-input"
        id="statusInActive"
        name="status"
        value="inactive"
      )
      label(for="statusInActive" class="form-check-label") Dừng hoạt động
    div(class="form-group mb-3")
      button(
        type="submit"
        class="btn btn-primary"
      ) Tạo mới   



  script(src="/admin/js/product-category.js") 
  script(src="/admin/js/create-category-tree.js") 