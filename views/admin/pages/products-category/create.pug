extend ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/render-tree.pug

block main
  +alert-error(5000)
  if(role.permissions.includes("products-category_create"))
    h1(class="mb-4") Thêm mới danh mục sản phẩm
    div(class="mb-3")
      a(
        href=`${prefixAdmin}/products-category`
        class="btn btn-secondary"
      ) Quay lại

    form(
      action=`${prefixAdmin}/products-category/create`
      method="POST"
      enctype="multipart/form-data"
    )
      div(class="form-group mb-3")
        label(for="title") Tiêu đề
        input(
          type="text"
          class="form-control"
          id="title"
          name="title"
          required
        )
      div(class="form-group mb-3")
        label(for="parent_id") Danh mục cha
          if(records)
            +tree-select(records)


      div(class="form-group mb-3")
        label(for="desc") Mô tả
        textarea(
          class="form-control textarea-mce"
          id="desc"
          name="description"
          rows="5"
          
        ) 
      div(
        class="form-group mb-3"
        upload-image
      )
        label(for="thumbnail") Ảnh
        input(
          type="file"
          class="form-control-file"
          id="thumbnail"
          name="thumbnail"
          accept="image/*"
          upload-image-input
        )
        br
        .image-preview-wrapper
          img(
            src=""
            class="image-preview"
            upload-image-preview
          ) 
          span(
            remove-image-preview  
            class="remove-image"
          ) x
      
      div(class="form-group mb-3")
        label(for="position") Vị trí
        input(
          type="number"
          class="form-control"
          id="position"
          name="position"
          placeholder="Tự động tăng"
          min="1"
        )

      
      label Trạng thái
      br
      div(class="form-group form-check form-check-inline mb-3")
        input(
          type="radio"
          class="form-check-input"
          id="statusActive"
          name="status"
          value="active"
          checked
        )
        label(for="statusActive" class="form-check-label") Hoạt động
      div(class="form-group form-check form-check-inline mb-3")
        input(
          type="radio"
          class="form-check-input"
          id="statusInActive"
          name="status"
          value="inactive"
        )
        label(for="statusInActive" class="form-check-label") Dừng hoạt động
      div(class="form-group mb-3")
        button(
          type="submit"
          class="btn btn-primary"
        ) Tạo mới   



    script(src="/admin/js/product-category.js") 
    script(src="/admin/js/tree.js") 
  else 
    h1 Bạn không có quyền truy cập