extend ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/render-tree.pug

block main
  +alert-error(5000)
  +alert-success(5000)

  h1(class="mb-4") Cập nhật thông tin cá nhân

  div(class="mb-3")
    a(
      href=`${prefixAdmin}/my-account`
      class="btn btn-secondary"
    ) Quay lại

  form(
    action=`${prefixAdmin}/my-account/edit?_method=PATCH`
    method="POST"
    enctype="multipart/form-data"
  )
    div(class="form-group mb-3")
      label(for="fullName") Họ và tên *
      input(
        type="text"
        class="form-control"
        id="fullName"
        name="fullName"
        required
        value=user.fullName
      )

    div(class="form-group mb-3")
      label(for="email") Email *
      input(
        type="email"
        class="form-control"
        id="email"
        name="email"
        required
        value=user.email
      )

    div(class="form-group mb-3")
      label(for="password") Mật khẩu *
      input(
        type="password"
        class="form-control"
        id="password"
        name="password"
        placeholder="*Để trống nếu không đổi mật khẩu"
      )
    
    div(class="form-group mb-3")
      label(for="phone") Số điện thoại
      input(
        type="text"
        class="form-control"
        id="phone"
        name="phone"
        value=user.phone
      )
    
    div(
      class="form-group mb-3"
      upload-image
    )
      label(for="avatar") Ảnh
      input(
        type="file"
        class="form-control-file"
        id="avatar"
        name="avatar"
        accept="image/*"
        upload-image-input
      )
      br
      .image-preview-wrapper
        img(
          src=user.avatar || ""
          class="image-preview"
          upload-image-preview
        ) 
        span(
          remove-image-preview  
          class="remove-image"
        ) x
       
    div(class="form-group mb-3")
      button(
        type="submit"
        class="btn btn-primary"
      ) Cập nhật 
