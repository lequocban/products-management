extend ../../layouts/default.pug
include ../../mixins/alert.pug


block main
  +alert-error(5000)
  +alert-success(5000)

  h1(class="mb-4") Chỉnh sửa nhóm quyền

  div(class="mb-3")
    a(
      href=`${prefixAdmin}/roles`
      class="btn btn-secondary"
    ) Quay lại

  form(
    action=`${prefixAdmin}/roles/edit/${record._id}?_method=PATCH`
    method="POST"
  )
    div(class="form-group mb-3")
      label(for="title") Tiêu đề
      input(
        type="text"
        class="form-control"
        id="title"
        name="title"
        required
        value=record.title
      )
    
    
    div(class="form-group mb-3")
      label(for="desc") Mô tả
      textarea(
        class="form-control"
        id="desc"
        name="description"
        rows="5"
      ) #{record.description}

    div(class="form-group mb-3")
      button(
        type="submit"
        class="btn btn-primary"
      ) Cập nhật 



