extend ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  +alert-success(5000)
  +alert-error(5000)

  if(role.permissions.includes("roles_view"))
    h1(class="mb-4") Chi tiết nhóm quyền

    

    //- Thẻ Card chứa nội dung (Đổ bóng nhẹ, bo góc)
    .card.shadow-sm.border-0
      //- Header của Card: Chứa tên nhóm quyền nổi bật
      .card-header.bg-light.border-bottom.pt-3.pb-3
        h4.m-0.text-primary #{record.title}

      .card-body.p-4
        .row.mb-3
          .col-md-3
            strong.text-muted Mô tả chi tiết:
          .col-md-9
            if record.description
              span !{record.description}
            else
              span.text-muted.fst-italic (Không có mô tả)
        
        hr.text-black-50

        .row.mb-4
          .col-md-3
            strong.text-muted Người tạo:
          .col-md-9
            if record.createdBy && record.createdBy.account_id
              span.text-primary #{record.createdBy.account_id.fullName} 
              br
              small.text-muted (#{new Date(record.createdBy.createdAt).toLocaleString("vi-VN")})
            else 
              span.text-muted Không xác định
        .row.mb-4
          .col-md-3
            strong.text-muted Lịch sử cập nhật:
          .col-md-9
            if record.updatedBy && record.updatedBy.length > 0
              //- Đảo ngược mảng để mới nhất lên đầu
              - const history = [...record.updatedBy].reverse()
              
              table.table.table-sm.table-bordered.mt-2
                thead.table-light
                  tr
                    th Thời gian
                    th Người cập nhật
                    th Id
                tbody
                  each item in history
                    tr
                      td #{new Date(item.updatedAt).toLocaleString("vi-VN")}
                      td 
                        if item.account_id && item.account_id.fullName
                          | #{item.account_id.fullName}
                      td 
                        if item.account_id && item.account_id.fullName
                          | #{item.account_id.id}
                        else 
                          span.text-muted Không xác định
            else
              p.text-muted.mt-2.fst-italic Chưa có lịch sử cập nhật.

        .row
          .col-12
            if(role.permissions.includes("roles_edit"))
              a(
                href=`${prefixAdmin}/roles/edit/${record._id}`
                class="btn btn-warning"
              ) Sửa

            a(
              href=`${prefixAdmin}/roles`
              class="btn btn-secondary ms-2"
            ) Quay lại
  else 
    h1 Bạn không có quyền truy cập