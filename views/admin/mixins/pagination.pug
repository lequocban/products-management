mixin pagination(pagination)
  nav
    ul(class="pagination")
      if(pagination.currentPage > 1)
        li(class="page-item")
          button(
            class=`page-link`
            btn-pagination=1
          ) Trang đầu

        li(class="page-item")
          button(
            class=`page-link`
            btn-pagination=pagination.currentPage-1
          ) Trang trước


      - for(i=1; i<= pagination.totalPage; i++)
        li(class=`page-item ${pagination.currentPage == i ? "active" : ""}`)
          button(
            class="page-link"
            btn-pagination=i
          ) #{i}
       

      if(pagination.currentPage < pagination.totalPage)
        li(class="page-item")
          button(
            class=`page-link`
            btn-pagination=pagination.currentPage+1
            ) Kế tiếp 

        li(class="page-item")
          button(
            class=`page-link`
            btn-pagination=pagination.totalPage
          ) Trang cuối