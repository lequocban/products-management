
mixin render-tree-list(items, current_id = "", parent_id = "")
  ul.tree-view
    each item in items
      if item.id != current_id
        //- Kiểm tra nếu id của item trùng với parent_id thì bôi đen
        - const isSelected = (item.id == parent_id) ? "selected" : ""
        
        li.tree-item(data-id=item.id class=isSelected)
          .item-content
            if item.children && item.children.length > 0
              span.toggle ▶
            else
              span.toggle.empty  
            span.title #{item.title}
          
          if item.children && item.children.length > 0
            .child-container(style="display: none;")
              //- Truyền tiếp các biến xuống cấp con
              +render-tree-list(item.children, current_id, parent_id)


//- 2. Mixin tổng (Wrapper) dùng để gọi ở file chính
//- Bao gồm cả Input ẩn, Cấu trúc khung và Danh mục gốc
mixin tree-select(records, current_id = "", parent_id = "", input_name = "parent_id")
  
  //- 1. Gán biến input_name vào thuộc tính name và id
  //- 2. Thêm thuộc tính đánh dấu "input-tree-value" cho JS dễ tìm
  input(
    type="hidden" 
    name=input_name 
    id=input_name 
    value=parent_id 
    input-tree-value
  )
  
  .tree-container
    - const isRootSelected = (parent_id === "") ? "selected" : ""
    
    .tree-item.root-item(data-id="" class=isRootSelected)
      .item-content
        span.toggle.empty
        span.title -- Danh mục gốc --
    
    if(records)
      +render-tree-list(records, current_id, parent_id)